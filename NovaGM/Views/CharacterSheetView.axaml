<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NovaGM.ViewModels"
             xmlns:models="clr-namespace:NovaGM.Models"
             x:Class="NovaGM.Views.CharacterSheetView"
             x:DataType="vm:CharacterSheetViewModel">

  <Grid ColumnDefinitions="2*,1.2*" RowDefinitions="Auto,*" Margin="8">
    <TextBlock Grid.ColumnSpan="2"
               Text="{Binding Header}"
               FontSize="18"
               FontWeight="Bold"
               Margin="0,0,0,8"/>

    <!-- Left: Silhouette + equipment slots -->
    <Border Grid.Row="1" Grid.Column="0"
            CornerRadius="{DynamicResource Radius.MD}"
            Background="{DynamicResource Brush.SurfaceAlt}"
            Padding="10">
      <Grid Margin="0,4,0,0"
            ColumnDefinitions="Auto,180,Auto"
            ColumnSpacing="12"
            RowSpacing="10">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: Head / Neck / Cloak -->
        <StackPanel Grid.Row="0"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="12">
          <Button Content="{Binding Head, TargetNullValue='Head Slot'}"
                  MinWidth="120"
                  Click="EquipmentSlot_Click"
                  Tag="Head"
                  ToolTip.Tip="Head slot — click to equip or change"/>
          <Button Content="{Binding Neck, TargetNullValue='Neck Slot'}"
                  MinWidth="120"
                  Click="EquipmentSlot_Click"
                  Tag="Neck"
                  ToolTip.Tip="Neck slot — click to equip or change"/>
          <Button Content="{Binding Cloak, TargetNullValue='Cloak Slot'}"
                  MinWidth="120"
                  Click="EquipmentSlot_Click"
                  Tag="Cloak"
                  ToolTip.Tip="Cloak slot — click to equip or change"/>
        </StackPanel>

        <!-- Left column -->
        <Button Grid.Row="1" Grid.Column="0"
                Content="{Binding Chest, TargetNullValue='Chest Slot'}"
                MinWidth="120"
                Click="EquipmentSlot_Click"
                Tag="Chest"
                ToolTip.Tip="Chest slot — click to equip or change"/>
        <Button Grid.Row="2" Grid.Column="0"
                Content="{Binding Hands, TargetNullValue='Hands Slot'}"
                MinWidth="120"
                Click="EquipmentSlot_Click"
                Tag="Hands"
                ToolTip.Tip="Hands slot — click to equip or change"/>
        <Button Grid.Row="3" Grid.Column="0"
                Content="{Binding MainHand, TargetNullValue='Main Hand'}"
                MinWidth="120"
                Click="EquipmentSlot_Click"
                Tag="MainHand"
                ToolTip.Tip="Main hand — weapon or tool"/>
        <Button Grid.Row="4" Grid.Column="0"
                Content="{Binding Ring1, TargetNullValue='Ring Slot'}"
                MinWidth="120"
                Click="EquipmentSlot_Click"
                Tag="Ring1"
                ToolTip.Tip="Ring slot 1 — click to equip or change"/>

        <!-- Center silhouette -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Grid.RowSpan="4"
                CornerRadius="12"
                Background="{DynamicResource Brush.SurfaceDeep}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                MinHeight="260"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch">
          <TextBlock Text="Humanoid"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource Brush.Muted}" />
        </Border>

        <!-- Feet centered below silhouette -->
        <Button Grid.Row="5"
                Grid.Column="1"
                Content="{Binding Feet, TargetNullValue='Feet Slot'}"
                MinWidth="140"
                HorizontalAlignment="Center"
                Click="EquipmentSlot_Click"
                Tag="Feet"
                ToolTip.Tip="Feet slot — click to equip or change"/>

        <!-- Right column -->
        <Button Grid.Row="1" Grid.Column="2"
                Content="{Binding Belt, TargetNullValue='Belt Slot'}"
                MinWidth="120"
                Click="EquipmentSlot_Click"
                Tag="Belt"
                ToolTip.Tip="Belt slot — click to equip or change"/>
        <Button Grid.Row="2" Grid.Column="2"
                Content="{Binding Legs, TargetNullValue='Legs Slot'}"
                MinWidth="120"
                Click="EquipmentSlot_Click"
                Tag="Legs"
                ToolTip.Tip="Legs slot — click to equip or change"/>
        <Button Grid.Row="3" Grid.Column="2"
                Content="{Binding OffHand, TargetNullValue='Off-hand'}"
                MinWidth="120"
                Click="EquipmentSlot_Click"
                Tag="OffHand"
                ToolTip.Tip="Off-hand — shield, secondary weapon, or tool"/>
        <Button Grid.Row="4" Grid.Column="2"
                Content="{Binding Ring2, TargetNullValue='Ring Slot'}"
                MinWidth="120"
                Click="EquipmentSlot_Click"
                Tag="Ring2"
                ToolTip.Tip="Ring slot 2 — click to equip or change"/>
      </Grid>
    </Border>

    <!-- Right: Stats & equipped list -->
    <Border Grid.Row="1" Grid.Column="1"
            CornerRadius="{DynamicResource Radius.MD}"
            Background="{DynamicResource Brush.SurfaceAlt}"
            Padding="12"
            Margin="8,0,0,0">
      <StackPanel Spacing="10">
        <TextBlock Text="Attributes" FontWeight="Bold"/>

        <!-- Simple two-column grid for stats with modifiers -->
        <UniformGrid Columns="2" Rows="6">
          <TextBlock Text="STR"/>
          <TextBlock Text="{Binding STRDisplay}"/>
          <TextBlock Text="DEX"/>
          <TextBlock Text="{Binding DEXDisplay}"/>
          <TextBlock Text="CON"/>
          <TextBlock Text="{Binding CONDisplay}"/>
          <TextBlock Text="INT"/>
          <TextBlock Text="{Binding INTDisplay}"/>
          <TextBlock Text="WIS"/>
          <TextBlock Text="{Binding WISDisplay}"/>
          <TextBlock Text="CHA"/>
          <TextBlock Text="{Binding CHADisplay}"/>
        </UniformGrid>

        <Separator/>

        <TextBlock Text="Equipped" FontWeight="Bold"/>
        <ScrollViewer MaxHeight="140" HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding EquippedList}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:Item">
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
                  <TextBlock Text="{Binding Slot}" MinWidth="64" Opacity="0.7"/>
                  <TextBlock Text="—" Opacity="0.5"/>
                  <TextBlock Text="{Binding Name}" TextWrapping="Wrap"/>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <Separator Margin="0,8,0,0"/>
        <TextBlock Text="Inventory" FontWeight="Bold" Margin="0,4,0,4"/>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding InventorySlots}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="7" Rows="7" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:InventorySlotViewModel">
                <Border Margin="2"
                        MinWidth="48" MinHeight="48"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.SurfaceAlt}"
                        BorderThickness="1"
                        ToolTip.Tip="{Binding Tooltip}">
                  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2" Margin="3">
                    <TextBlock Text="{Binding Name}"
                               FontSize="10"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding QuantityDisplay}"
                               FontSize="10"
                               Foreground="{DynamicResource Brush.Muted}"
                               HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
