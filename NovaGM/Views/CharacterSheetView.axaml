<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NovaGM.ViewModels"
             xmlns:models="clr-namespace:NovaGM.Models"
             x:Class="NovaGM.Views.CharacterSheetView"
             x:DataType="vm:CharacterSheetViewModel">

  <Grid ColumnDefinitions="2*,1.2*" RowDefinitions="Auto,*" Margin="4">
    <TextBlock Grid.ColumnSpan="2"
               Text="{Binding Header}"
               FontSize="18"
               FontWeight="Bold"
               Margin="0,0,0,8"/>

    <!-- Left: Silhouette + equipment slots -->
    <Border Grid.Row="1" Grid.Column="0"
            CornerRadius="{DynamicResource Radius.MD}"
            Background="{DynamicResource Brush.SurfaceAlt}"
            Padding="10">
      <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="0,4,0,0">

        <!-- Head / Neck / Cloak -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Margin="0,0,0,12">
          <Button Content="{Binding Head}" MinWidth="96"/>
          <Button Content="{Binding Neck}" MinWidth="96"/>
          <Button Content="{Binding Cloak}" MinWidth="96"/>
        </StackPanel>

        <!-- Core silhouette band with adjacent slots -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto"
              VerticalAlignment="Stretch"
              Margin="0,0,0,16">

          <StackPanel Grid.Column="0"
                      Orientation="Vertical"
                      VerticalAlignment="Center"
                      Spacing="10"
                      Margin="0,0,12,0">
            <Button Content="{Binding Chest}" MinWidth="120"/>
            <Button Content="{Binding Hands}" MinWidth="120"/>
          </StackPanel>

          <Border Grid.Column="1"
                  MinHeight="260"
                  CornerRadius="12"
                  Background="#151922"
                  BorderBrush="#2B3448"
                  BorderThickness="1"
                  Margin="0"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Stretch">
            <TextBlock Text="Humanoid"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource Brush.Muted}" />
          </Border>

          <StackPanel Grid.Column="2"
                      Orientation="Vertical"
                      VerticalAlignment="Center"
                      Spacing="10"
                      Margin="12,0,0,0">
            <Button Content="{Binding Belt}" MinWidth="120"/>
            <Button Content="{Binding Legs}" MinWidth="120"/>
          </StackPanel>
        </Grid>

        <!-- Feet slot -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20">
          <Button Content="{Binding Feet}" MinWidth="140"/>
        </StackPanel>

        <!-- Weapons & rings -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*" HorizontalAlignment="Stretch">
          <StackPanel Grid.Column="0"
                      Orientation="Vertical"
                      Spacing="10"
                      HorizontalAlignment="Left">
            <Button Content="{Binding MainHand}" MinWidth="120"/>
            <Button Content="{Binding Ring1}" MinWidth="120"/>
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Orientation="Vertical"
                      Spacing="10"
                      HorizontalAlignment="Right">
            <Button Content="{Binding OffHand}" MinWidth="120"/>
            <Button Content="{Binding Ring2}" MinWidth="120"/>
          </StackPanel>
        </Grid>

      </Grid>
    </Border>

    <!-- Right: Stats & equipped list -->
    <Border Grid.Row="1" Grid.Column="1"
            CornerRadius="{DynamicResource Radius.MD}"
            Background="{DynamicResource Brush.SurfaceAlt}"
            Padding="12"
            Margin="8,0,0,0">
      <StackPanel Spacing="10">
        <TextBlock Text="Attributes" FontWeight="Bold"/>

        <!-- Simple two-column grid for stats -->
        <UniformGrid Columns="2" Rows="6">
          <TextBlock Text="STR"/>
          <TextBlock Text="{Binding STR}"/>
          <TextBlock Text="DEX"/>
          <TextBlock Text="{Binding DEX}"/>
          <TextBlock Text="CON"/>
          <TextBlock Text="{Binding CON}"/>
          <TextBlock Text="INT"/>
          <TextBlock Text="{Binding INT}"/>
          <TextBlock Text="WIS"/>
          <TextBlock Text="{Binding WIS}"/>
          <TextBlock Text="CHA"/>
          <TextBlock Text="{Binding CHA}"/>
        </UniformGrid>

        <Separator/>

        <TextBlock Text="Equipped" FontWeight="Bold"/>
        <ItemsControl ItemsSource="{Binding EquippedList}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:Item">
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                <TextBlock Text="{Binding Slot}"/>
                <TextBlock Text="—"/>
                <TextBlock Text="{Binding Name}"/>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
