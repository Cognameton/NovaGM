<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NovaGM.Views.DetailedCharacterWindow"
        Title="Character Sheet"
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner">

  <ScrollViewer Margin="20">
    <StackPanel Spacing="15">
      
      <!-- Character Header -->
      <Border Background="{DynamicResource Brush.SurfaceAlt}" 
              CornerRadius="8" 
              Padding="15">
        <StackPanel>
          <TextBlock x:Name="CharacterName" 
                     FontSize="20" 
                     FontWeight="Bold" 
                     HorizontalAlignment="Center"/>
          <TextBlock x:Name="CharacterDetails" 
                     FontSize="14" 
                     HorizontalAlignment="Center" 
                     Margin="0,5,0,0"/>
        </StackPanel>
      </Border>

      <!-- Ability Scores -->
      <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="15">
        <StackPanel>
          <TextBlock Text="Ability Scores" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
          
          <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" Margin="0,0,0,15">
            <Border Grid.Column="0" Grid.Row="0" 
                    Background="{DynamicResource Brush.Surface}" 
                    CornerRadius="5" 
                    Padding="10" 
                    Margin="0,0,5,5">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="STR" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CharacterSTR" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                <TextBlock x:Name="STRModifier" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
              </StackPanel>
            </Border>
            
            <Border Grid.Column="1" Grid.Row="0" 
                    Background="{DynamicResource Brush.Surface}" 
                    CornerRadius="5" 
                    Padding="10" 
                    Margin="5,0,5,5">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="DEX" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CharacterDEX" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                <TextBlock x:Name="DEXModifier" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
              </StackPanel>
            </Border>
            
            <Border Grid.Column="2" Grid.Row="0" 
                    Background="{DynamicResource Brush.Surface}" 
                    CornerRadius="5" 
                    Padding="10" 
                    Margin="5,0,0,5">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="CON" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CharacterCON" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                <TextBlock x:Name="CONModifier" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
              </StackPanel>
            </Border>
            
            <Border Grid.Column="0" Grid.Row="1" 
                    Background="{DynamicResource Brush.Surface}" 
                    CornerRadius="5" 
                    Padding="10" 
                    Margin="0,0,5,0">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="INT" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CharacterINT" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                <TextBlock x:Name="INTModifier" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
              </StackPanel>
            </Border>
            
            <Border Grid.Column="1" Grid.Row="1" 
                    Background="{DynamicResource Brush.Surface}" 
                    CornerRadius="5" 
                    Padding="10" 
                    Margin="5,0,5,0">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="WIS" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CharacterWIS" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                <TextBlock x:Name="WISModifier" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
              </StackPanel>
            </Border>
            
            <Border Grid.Column="2" Grid.Row="1" 
                    Background="{DynamicResource Brush.Surface}" 
                    CornerRadius="5" 
                    Padding="10" 
                    Margin="5,0,0,0">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="CHA" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CharacterCHA" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                <TextBlock x:Name="CHAModifier" HorizontalAlignment="Center" FontSize="12" Foreground="Gray"/>
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Character Statistics -->
      <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="15">
        <StackPanel>
          <TextBlock Text="Character Information" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
          
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Player:" FontWeight="SemiBold" Margin="0,0,15,0"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PlayerName"/>
            
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Race:" FontWeight="SemiBold" Margin="0,0,15,0"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CharacterRace"/>
            
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Class:" FontWeight="SemiBold" Margin="0,0,15,0"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CharacterClass"/>
            
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Level:" FontWeight="SemiBold" Margin="0,0,15,0"/>
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="CharacterLevel"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Close Button -->
      <Button Content="Close" 
              HorizontalAlignment="Center" 
              MinWidth="100"
              Click="OnCloseClick"/>
      
    </StackPanel>
  </ScrollViewer>
</Window>