<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NovaGM.Views.SettingsWindow"
        Width="620" Height="420"
        CanResize="False"
        Title="Settings — NovaGM">

  <Border Padding="16">
    <Grid RowDefinitions="Auto,* ,Auto">
      <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" />

      <StackPanel Grid.Row="1" Spacing="14" Margin="0,12,0,0">

        <!-- Rooms -->
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <CheckBox x:Name="ChkSingleRoom" Content="Single room (recommended on CPU)" />
        </StackPanel>

        <!-- GPU -->
        <StackPanel Spacing="6">
          <CheckBox x:Name="ChkUseGpu" Content="Use GPU acceleration" />
          <StackPanel Orientation="Horizontal" Spacing="10" Margin="18,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="GPU layers:" VerticalAlignment="Center"/>
            <Slider x:Name="SldGpuLayers" Minimum="0" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True" Width="220"/>
            <TextBlock x:Name="LblGpuLayers" Text="0" Width="28" HorizontalAlignment="Left" />
          </StackPanel>
          <TextBlock Text="Tip: Start low (e.g., 8–12). Higher = more VRAM, faster tokens."
                     Opacity="0.7" FontSize="12" Margin="18,0,0,0"/>
        </StackPanel>

        <!-- Narration length -->
        <StackPanel Spacing="6">
          <TextBlock Text="Narration length (tokens)" />
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Slider x:Name="SldNarrTokens" Minimum="120" Maximum="360" TickFrequency="10" IsSnapToTickEnabled="True" Width="300"/>
            <TextBlock x:Name="LblNarrTokens" Text="260" Width="40"/>
          </StackPanel>
        </StackPanel>

        <!-- LAN hosting -->
        <StackPanel Spacing="6">
          <CheckBox x:Name="ChkAllowLan" Content="Allow LAN clients (bind to all interfaces)" />
          <StackPanel Orientation="Horizontal" Spacing="10" Margin="18,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="Port:" VerticalAlignment="Center"/>
            <TextBox x:Name="TxtPort" Width="80" Watermark="5055"/>
            <!-- angle brackets must be escaped in XAML attributes -->
            <TextBlock Text="Players visit http://&lt;your-LAN-IP&gt;:PORT (e.g., 192.168.1.23:5055)" Opacity="0.7" />
          </StackPanel>
        </StackPanel>

        <TextBlock x:Name="InfoText"
                   Text="Changes to GPU or LAN binding take effect after restart."
                   FontSize="12" Opacity="0.7"/>
      </StackPanel>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
        <Button Content="Cancel" MinWidth="88" Click="CancelButton_Click"/>
        <Button Content="Save" MinWidth="88" IsDefault="True" Click="SaveButton_Click"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
