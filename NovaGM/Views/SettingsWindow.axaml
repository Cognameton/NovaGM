<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NovaGM.Views.SettingsWindow"
        Width="640" Height="440"
        MinWidth="520" MinHeight="380"
        CanResize="True"
        Title="Settings — NovaGM">

  <Border Padding="16">
    <Grid RowDefinitions="Auto,* ,Auto">
      <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" />

      <StackPanel Grid.Row="1" Spacing="14" Margin="0,12,0,0">

        <!-- Rooms -->
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <CheckBox x:Name="ChkSingleRoom" Content="Single room (recommended on CPU)" />
        </StackPanel>

        <!-- GPU -->
        <StackPanel Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="16">
            <CheckBox x:Name="ChkUseGpu" Content="Use GPU acceleration" />
            <CheckBox x:Name="ChkFullGpuOffload" Content="Full GPU offload" />
          </StackPanel>
          <Grid ColumnDefinitions="Auto,*,40" Margin="18,0,0,0" VerticalAlignment="Center">
            <TextBlock Grid.Column="0" Text="GPU layers:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Slider Grid.Column="1" x:Name="SldGpuLayers" Minimum="0" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True"/>
            <TextBlock Grid.Column="2" x:Name="LblGpuLayers" Text="0" VerticalAlignment="Center" Margin="6,0,0,0"/>
          </Grid>
          <TextBlock Text="Tip: Full GPU offload pushes all layers to VRAM. Use the slider for partial offload."
                     Opacity="0.7" FontSize="12" Margin="18,0,0,0"/>
        </StackPanel>

        <!-- Narration length -->
        <StackPanel Spacing="6">
          <TextBlock Text="Narration length (tokens)" />
          <Grid ColumnDefinitions="*,40" VerticalAlignment="Center">
            <Slider Grid.Column="0" x:Name="SldNarrTokens" Minimum="120" Maximum="360" TickFrequency="10" IsSnapToTickEnabled="True"/>
            <TextBlock Grid.Column="1" x:Name="LblNarrTokens" Text="260" VerticalAlignment="Center" Margin="6,0,0,0"/>
          </Grid>
        </StackPanel>

        <!-- LAN hosting -->
        <StackPanel Spacing="6">
          <CheckBox x:Name="ChkAllowLan" Content="Allow LAN clients (bind to all interfaces)" />
          <Grid ColumnDefinitions="Auto,80,*" Margin="18,0,0,0" VerticalAlignment="Center">
            <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" x:Name="TxtPort" Watermark="5055"/>
            <TextBlock Grid.Column="2" Text="Players visit http://&lt;your-LAN-IP&gt;:PORT"
                       Opacity="0.7" VerticalAlignment="Center" Margin="10,0,0,0"
                       TextWrapping="Wrap"/>
          </Grid>
        </StackPanel>

        <TextBlock x:Name="InfoText"
                   Text="Changes to GPU or LAN binding take effect after restart."
                   FontSize="12" Opacity="0.7"/>
      </StackPanel>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
        <Button Content="Cancel" MinWidth="88" Click="CancelButton_Click"/>
        <Button Content="Save" MinWidth="88" IsDefault="True" Click="SaveButton_Click"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
