<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:NovaGM.Models"
        x:Class="NovaGM.Views.EquipmentSelectionDialog"
        Title="Select Item to Equip"
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner">
  
  <Grid RowDefinitions="Auto,*,Auto" Margin="16">
    
    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,12">
      <TextBlock Text="Select Item to Equip" FontSize="18" FontWeight="Bold"/>
      <TextBlock x:Name="SlotLabel" Text="Slot: MainHand" Foreground="{DynamicResource Brush.Muted}" Margin="0,4,0,0"/>
    </StackPanel>
    
    <!-- Item List -->
    <Border Grid.Row="1" 
            CornerRadius="{DynamicResource Radius.MD}"
            Background="{DynamicResource Brush.SurfaceAlt}"
            Padding="12"
            BorderBrush="{DynamicResource Brush.Surface}"
            BorderThickness="1">
      <ScrollViewer>
        <ListBox x:Name="ItemList" 
                 Background="Transparent"
                 SelectionMode="Single">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:InventoryEntry">
              <Border Background="{DynamicResource Brush.Surface}"
                      CornerRadius="6"
                      Padding="12"
                      Margin="0,4">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                  <TextBlock Text="{Binding ItemId}" 
                             FontSize="11" 
                             Foreground="{DynamicResource Brush.Muted}"/>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Quantity:" FontSize="12" Foreground="{DynamicResource Brush.Muted}"/>
                    <TextBlock Text="{Binding Quantity}" FontSize="12"/>
                  </StackPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </ScrollViewer>
    </Border>
    
    <!-- Buttons -->
    <StackPanel Grid.Row="2" 
                Orientation="Horizontal" 
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,12,0,0">
      <Button Content="Cancel" 
              MinWidth="100"
              Click="Cancel_Click"/>
      <Button Content="Equip" 
              MinWidth="100"
              Click="Equip_Click"
              IsEnabled="{Binding #ItemList.SelectedItem, Converter={StaticResource NullToBool}}"/>
    </StackPanel>
    
  </Grid>
</Window>
