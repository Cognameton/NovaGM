<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NovaGM.Views.ModelsWindow"
        Width="520" Height="260"
        MinWidth="400"
        CanResize="True"
        Title="Models — Assign Roles">

  <Border Padding="16">
    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*">
      <TextBlock Text="Assign GGUF models to roles" FontSize="18" FontWeight="SemiBold" />

      <Grid Grid.Row="1" Margin="0,12,0,0" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="10" RowSpacing="10">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Controller:" VerticalAlignment="Center"/>
        <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="CmbController" HorizontalAlignment="Stretch"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Narrator:" VerticalAlignment="Center"/>
        <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="CmbNarrator" HorizontalAlignment="Stretch"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Memory:" VerticalAlignment="Center"/>
        <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="CmbMemory" HorizontalAlignment="Stretch"/>
      </Grid>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
        <Button Content="Open llm folder" Click="OpenFolder_Click"/>
        <Button Content="Cancel" Click="Cancel_Click"/>
        <Button Content="Save" IsDefault="True" Click="Save_Click"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
