<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NovaGM.Views"
        x:Class="NovaGM.Views.SaveMissionWindow"
        x:DataType="vm:SaveMissionWindow"
        Width="500" Height="420"
        CanResize="False"
        Title="Save as Mission — NovaGM">

  <Border Padding="16">
    <Grid RowDefinitions="Auto,*,Auto">
      <TextBlock Text="Save Current Session as Mission" FontSize="18" FontWeight="SemiBold"/>

      <ScrollViewer Grid.Row="1" Margin="0,16,0,16">
        <StackPanel Spacing="12">
          
          <!-- Mission Name -->
          <StackPanel Spacing="4">
            <TextBlock Text="Mission Name *" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtMissionName" 
                     Watermark="Enter a name for this mission..."/>
          </StackPanel>

          <!-- Description -->
          <StackPanel Spacing="4">
            <TextBlock Text="Description"/>
            <TextBox x:Name="TxtDescription" 
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="80"
                     Watermark="Optional description (auto-generated if left blank)..."/>
          </StackPanel>

          <!-- Genre -->
          <StackPanel Spacing="4">
            <TextBlock Text="Genre"/>
            <ComboBox x:Name="CmbGenre">
              <ComboBoxItem Content="Fantasy" IsSelected="True"/>
              <ComboBoxItem Content="Sci-Fi"/>
              <ComboBoxItem Content="Horror"/>
              <ComboBoxItem Content="Modern"/>
              <ComboBoxItem Content="Historical"/>
              <ComboBoxItem Content="Mystery"/>
              <ComboBoxItem Content="Adventure"/>
              <ComboBoxItem Content="Other"/>
            </ComboBox>
          </StackPanel>

          <!-- Difficulty -->
          <StackPanel Spacing="4">
            <TextBlock Text="Difficulty Level"/>
            <ComboBox x:Name="CmbDifficulty">
              <ComboBoxItem Content="Easy"/>
              <ComboBoxItem Content="Medium" IsSelected="True"/>
              <ComboBoxItem Content="Hard"/>
              <ComboBoxItem Content="Expert"/>
            </ComboBox>
          </StackPanel>

          <!-- Session Summary -->
          <StackPanel Spacing="4">
            <TextBlock Text="Session Summary" FontWeight="SemiBold"/>
            <Border Background="{DynamicResource Brush.SurfaceAlt}"
                    CornerRadius="4"
                    Padding="8">
              <StackPanel Spacing="4">
                <TextBlock x:Name="LblSessionStats" 
                           FontSize="12"/>
                <TextBlock x:Name="LblGameState" 
                           FontSize="12" 
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Preview -->
          <StackPanel Spacing="4">
            <TextBlock Text="Mission Preview" FontWeight="SemiBold"/>
            <Border Background="{DynamicResource Brush.SurfaceAlt}"
                    CornerRadius="4"
                    Padding="8"
                    Height="80">
              <ScrollViewer>
                <TextBlock x:Name="LblPreview" 
                           TextWrapping="Wrap"
                           FontSize="12"/>
              </ScrollViewer>
            </Border>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>

      <!-- Buttons -->
      <StackPanel Grid.Row="2" 
                  Orientation="Horizontal" 
                  HorizontalAlignment="Right" 
                  Spacing="8">
        <Button Content="Cancel" 
                MinWidth="80" 
                Click="Cancel_Click"/>
        <Button Content="Save Mission" 
                MinWidth="100" 
                IsDefault="True" 
                Click="SaveMission_Click"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>