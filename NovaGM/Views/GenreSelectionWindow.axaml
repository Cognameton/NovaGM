<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NovaGM.Views"
        x:Class="NovaGM.Views.GenreSelectionWindow"
        Title="Select Game Genre"
        Width="620" Height="520"
        MinWidth="500" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Title -->
    <TextBlock Grid.Row="0" Text="Choose Game Genre" 
               FontSize="18" FontWeight="Bold" 
               HorizontalAlignment="Center" 
               Margin="0,0,0,20"/>

    <!-- Warning Message -->
    <Border Grid.Row="1" 
            Background="Orange" 
            CornerRadius="5" 
            Padding="10" 
            Margin="0,0,0,20">
      <TextBlock Text="⚠️ Warning: Genre and custom content cannot be modified once the game starts!" 
                 FontWeight="SemiBold" 
                 TextWrapping="Wrap" 
                 Foreground="White"/>
    </Border>

    <!-- Genre Selection and Preview -->
    <Grid Grid.Row="2" ColumnDefinitions="Auto,*">
      
      <!-- Genre Selection + Custom Content (left column) -->
      <Grid Grid.Column="0" MinWidth="160" Margin="0,0,16,0"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
        <TextBlock Grid.Row="0" Text="Genre:" FontWeight="SemiBold" Margin="0,0,0,10"/>
        <RadioButton Grid.Row="1" x:Name="FantasyRadio" Content="Fantasy" IsChecked="True" GroupName="Genre" Margin="0,4"/>
        <RadioButton Grid.Row="2" x:Name="SciFiRadio" Content="Sci-Fi" GroupName="Genre" Margin="0,4"/>
        <RadioButton Grid.Row="3" x:Name="HorrorRadio" Content="Horror" GroupName="Genre" Margin="0,4"/>

        <Separator Grid.Row="4" Margin="0,16"/>

        <TextBlock Grid.Row="5" Text="Custom Content:" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <Button Grid.Row="6" x:Name="AddRaceButton" Content="Add Custom Race" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
        <Button Grid.Row="7" x:Name="AddClassButton" Content="Add Custom Class" Margin="0,0,0,12" HorizontalAlignment="Stretch"/>

        <!-- Added content list lives here — no overlap possible -->
        <ScrollViewer Grid.Row="8" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <TextBlock Text="Added:" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <ListBox x:Name="CustomContentList">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="views:CustomContentItem">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{Binding Type}" FontWeight="SemiBold" MinWidth="52"/>
                    <TextBlock Text=":" Opacity="0.5"/>
                    <TextBlock Text="{Binding Name}" TextWrapping="Wrap"/>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </ScrollViewer>
      </Grid>

      <!-- Preview Panel -->
      <ScrollViewer Grid.Column="1">
        <StackPanel>
          <TextBlock Text="Preview:" FontWeight="SemiBold" Margin="0,0,0,10"/>
          
          <!-- Races Preview -->
          <Expander Header="Available Races" IsExpanded="True" Margin="0,5">
            <ListBox x:Name="RacesPreview" MaxHeight="120">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="views:PreviewItem">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Description}" FontSize="10" Foreground="Gray"/>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Expander>

          <!-- Classes Preview -->
          <Expander Header="Available Classes" IsExpanded="True" Margin="0,5">
            <ListBox x:Name="ClassesPreview" MaxHeight="120">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="views:PreviewItem">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Description}" FontSize="10" Foreground="Gray"/>
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Expander>

          <!-- Skills Preview -->
          <Expander Header="Available Skills" IsExpanded="False" Margin="0,5">
            <ListBox x:Name="SkillsPreview" MaxHeight="100">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="views:PreviewItem">
                  <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Expander>

          <!-- Weapons Preview -->
          <Expander Header="Available Weapons" IsExpanded="False" Margin="0,5">
            <ListBox x:Name="WeaponsPreview" MaxHeight="100">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="views:PreviewItem">
                  <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Expander>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- Buttons -->
    <StackPanel Grid.Row="3"
                Orientation="Horizontal" 
                HorizontalAlignment="Right" 
                Spacing="10">
      <Button x:Name="CancelButton" Content="Cancel" MinWidth="80"/>
      <Button x:Name="OkButton" Content="Apply Genre" MinWidth="80" Classes="accent"/>
    </StackPanel>

  </Grid>
</Window>