<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NovaGM.ViewModels"
        xmlns:m="clr-namespace:NovaGM.Models"
        xmlns:views="clr-namespace:NovaGM.Views"
        x:Class="NovaGM.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1000" Height="700">

  <DockPanel>

    <!-- Top menu -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="_New Game" Command="{Binding NewGameCommand}" />
        <MenuItem Header="_Continue Game" Command="{Binding ContinueGameCommand}" />
        <Separator/>
        <MenuItem Header="_Save to Journal" Command="{Binding SaveToJournalCommand}" />
        <MenuItem Header="_Save as Mission" Command="{Binding SaveAsMissionCommand}" />
        <Separator/>
        <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
      </MenuItem>

      <MenuItem Header="_Players">
        <MenuItem Header="_Kick Player" Command="{Binding KickPlayerCommand}" />
        <MenuItem Header="_Load Scenario" Command="{Binding LoadScenarioCommand}" />
      </MenuItem>

      <MenuItem Header="_Packs">
        <MenuItem Header="_Manage Packs" Command="{Binding OpenPacksCommand}" />
      </MenuItem>

      <MenuItem Header="_View">
        <MenuItem Header="_Models" Command="{Binding OpenModelsCommand}" />
        <MenuItem Header="_Settings" Command="{Binding OpenSettingsCommand}" />
      </MenuItem>

      <MenuItem Header="_Help">
        <MenuItem Header="_About" Command="{Binding AboutCommand}" />
      </MenuItem>
    </Menu>

    <!-- Server Status Panel -->
    <Border DockPanel.Dock="Top" 
            Background="{DynamicResource Brush.SurfaceAlt}" 
            Padding="10,8">
      <Grid ColumnDefinitions="*,Auto,200">
        
        <!-- Server Info -->
        <StackPanel Grid.Column="0" 
                    Orientation="Horizontal" 
                    Spacing="12"
                    VerticalAlignment="Center">
          <TextBlock Text="Room:" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding RoomCode}" 
                     VerticalAlignment="Center" 
                     FontFamily="Consolas" 
                     FontWeight="Bold"
                     FontSize="14"/>
          <TextBlock Text="Players join at:" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding ServerUrl}" 
                     VerticalAlignment="Center" 
                     FontFamily="Consolas"
                     FontSize="12"/>
        </StackPanel>

        <!-- Connected Players -->
        <StackPanel Grid.Column="2" 
                    VerticalAlignment="Center">
          <TextBlock Text="Connected Players:" FontWeight="SemiBold" FontSize="12"/>
          <ItemsControl ItemsSource="{Binding ConnectedPlayers}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{DynamicResource Brush.Surface}"
                        CornerRadius="4"
                        Padding="6,2"
                        Margin="2">
                  <TextBlock Text="{Binding}" FontSize="11"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
        
      </Grid>
    </Border>

    <!-- Main tabs -->
    <TabControl>
      <!-- Session tab -->
      <TabItem Header="Session">
        <Grid RowDefinitions="*,Auto" Margin="10">
          <ScrollViewer Grid.Row="0">
            <ItemsControl ItemsSource="{Binding Messages}">
              <ItemsControl.ItemTemplate>
                <!-- compiled binding needs x:DataType -->
                <DataTemplate x:DataType="vm:Message">
                  <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="{Binding Role}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap"/>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
            <TextBox Text="{Binding Input, Mode=TwoWay}" Watermark="Your action..." />
            <Button Grid.Column="1"
                    Content="Send"
                    Margin="8,0,0,0"
                    Command="{Binding SendCommand}" />
          </Grid>
        </Grid>
      </TabItem>

      <!-- Character tab -->
      <TabItem Header="Character">
        <views:CharacterSheetView DataContext="{Binding CharacterSheet}" />
      </TabItem>

      <!-- Journal tab -->
      <TabItem Header="Journal">
        <Grid RowDefinitions="*,Auto" Margin="10">
          <ListBox ItemsSource="{Binding JournalEntries}">
            <ListBox.ItemTemplate>
              <!-- DO NOT redeclare xmlns here; root already has it -->
              <DataTemplate x:DataType="x:String">
                <TextBlock Text="{Binding .}"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
            <TextBox Text="{Binding NewJournalText, Mode=TwoWay}" Watermark="Add entry..."/>
            <Button Grid.Column="1"
                    Content="Add"
                    Margin="8,0,0,0"
                    Command="{Binding AddJournalEntryCommand}" />
          </Grid>
        </Grid>
      </TabItem>

      <!-- Library tab -->
      <TabItem Header="Library">
        <ListBox ItemsSource="{Binding Compendium}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="m:CompendiumEntry">
              <StackPanel Margin="0,0,0,8">
                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </TabItem>
    </TabControl>

  </DockPanel>
</Window>
