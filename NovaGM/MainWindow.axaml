<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NovaGM.ViewModels"
        xmlns:m="clr-namespace:NovaGM.Models"
        xmlns:views="clr-namespace:NovaGM.Views"
        x:Class="NovaGM.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1000" Height="700">

  <DockPanel>

    <!-- Top menu -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="_New Game" Command="{Binding NewGameCommand}" />
        <MenuItem Header="_Continue Game" Command="{Binding ContinueGameCommand}" />
        <Separator/>
        <MenuItem Header="_Save to Journal" Command="{Binding SaveToJournalCommand}" />
        <MenuItem Header="_Save as Mission" Command="{Binding SaveAsMissionCommand}" />
        <Separator/>
        <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
      </MenuItem>

      <MenuItem Header="_Players">
        <MenuItem Header="_View Players" Command="{Binding ViewPlayersCommand}" />
        <MenuItem Header="_Kick Player" Command="{Binding KickPlayerCommand}" />
        <MenuItem Header="_Load Scenario" Command="{Binding LoadScenarioCommand}" />
      </MenuItem>

      <MenuItem Header="_Packs">
        <MenuItem Header="_Manage Packs" Command="{Binding OpenPacksCommand}" />
      </MenuItem>

      <MenuItem Header="_View">
        <MenuItem Header="_Models" Command="{Binding OpenModelsCommand}" />
        <MenuItem Header="_Settings" Command="{Binding OpenSettingsCommand}" />
      </MenuItem>

      <MenuItem Header="_Genre">
        <MenuItem Header="_Select Genre" Command="{Binding SelectGenreCommand}" />
      </MenuItem>

      <MenuItem Header="_Help">
        <MenuItem Header="_About" Command="{Binding AboutCommand}" />
      </MenuItem>
    </Menu>

    <!-- Server Status Panel -->
    <Border DockPanel.Dock="Top" 
            Background="{DynamicResource Brush.SurfaceAlt}" 
            Padding="10,8">
      <Grid ColumnDefinitions="*,Auto,200">
        
        <!-- Server Info -->
        <StackPanel Grid.Column="0" 
                    Orientation="Horizontal" 
                    Spacing="12"
                    VerticalAlignment="Center">
          <TextBlock Text="Room:" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding RoomCode}" 
                     VerticalAlignment="Center" 
                     FontFamily="Consolas" 
                     FontWeight="Bold"
                     FontSize="14"/>
          <TextBlock Text="Players join at:" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding ServerUrl}" 
                     VerticalAlignment="Center" 
                     FontFamily="Consolas"
                     FontSize="12"/>
        </StackPanel>

        <!-- Connected Players -->
        <StackPanel Grid.Column="2" 
                    VerticalAlignment="Center">
          <TextBlock Text="Connected Players:" FontWeight="SemiBold" FontSize="12"/>
          <ItemsControl ItemsSource="{Binding ConnectedPlayers}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{DynamicResource Brush.Surface}"
                        CornerRadius="4"
                        Padding="6,2"
                        Margin="2">
                  <TextBlock Text="{Binding}" FontSize="11"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
        
      </Grid>
    </Border>

    <!-- Main tabs -->
    <TabControl>
      <!-- Session tab -->
      <TabItem Header="Session">
        <Grid RowDefinitions="*,Auto" Margin="10">
          <ScrollViewer Grid.Row="0">
            <ItemsControl ItemsSource="{Binding Messages}">
              <ItemsControl.ItemTemplate>
                <!-- compiled binding needs x:DataType -->
                <DataTemplate x:DataType="vm:Message">
                  <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="{Binding Role}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap"/>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
            <TextBox Text="{Binding Input, Mode=TwoWay}" Watermark="Your action..." />
            <Button Grid.Column="1"
                    Content="Send"
                    Margin="8,0,0,0"
                    Command="{Binding SendCommand}" />
          </Grid>
        </Grid>
      </TabItem>

      <!-- Character tab -->
      <TabItem Header="Character">
        <TabControl>
          <TabItem Header="Hub Characters">
            <Grid ColumnDefinitions="220,*" Margin="10" ColumnSpacing="10">
              <Border Grid.Column="0"
                      Background="{DynamicResource Brush.SurfaceAlt}"
                      CornerRadius="{DynamicResource Radius.MD}"
                      Padding="12">
                <StackPanel Spacing="8">
                  <TextBlock Text="Characters on this hub" FontWeight="SemiBold" />
                  <TextBlock Text="Select a character to view their sheet." FontSize="12" Foreground="{DynamicResource Brush.Muted}" />

                  <Button Content="Create Character"
                          Command="{Binding CreateHubCharacterCommand}"
                          HorizontalAlignment="Stretch"
                          Margin="0,0,0,8" />

                  <ListBox ItemsSource="{Binding HubCharacters}"
                           SelectedItem="{Binding SelectedHubCharacter, Mode=TwoWay}"
                           MinHeight="180">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:CharacterSheetViewModel">
                        <StackPanel Margin="4,2" Spacing="2">
                          <TextBlock Text="{Binding Character.Name}" FontWeight="Bold" />
                          <TextBlock Text="{Binding Header}" FontSize="11" Foreground="{DynamicResource Brush.Muted}" />
                        </StackPanel>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <TextBlock Text="No hub characters yet. Use the character creator to add one."
                             FontStyle="Italic"
                             Foreground="{DynamicResource Brush.Muted}"
                             IsVisible="{Binding HubCharacters.Count, Converter={StaticResource ZeroToBool}}" />
                </StackPanel>
              </Border>

              <Border Grid.Column="1"
                      Background="{DynamicResource Brush.SurfaceAlt}"
                      CornerRadius="{DynamicResource Radius.MD}"
                      Padding="12">
                <Grid>
                  <ContentControl Content="{Binding SelectedHubCharacter}"
                                  IsVisible="{Binding SelectedHubCharacter, Converter={StaticResource NullToBool}}">
                    <ContentControl.ContentTemplate>
                      <DataTemplate x:DataType="vm:CharacterSheetViewModel">
                        <views:CharacterSheetView DataContext="{Binding}" />
                      </DataTemplate>
                    </ContentControl.ContentTemplate>
                  </ContentControl>

                  <TextBlock Text="Select or create a character to view their sheet."
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource Brush.Muted}"
                             IsVisible="{Binding SelectedHubCharacter, Converter={StaticResource NullToBoolInverted}}" />
                </Grid>
              </Border>
            </Grid>
          </TabItem>

          <TabItem Header="Connected Players">
            <Grid Margin="10">
              <Grid IsVisible="{Binding IsRemotePlayerListVisible}">
                <StackPanel Spacing="12">
                  <TextBlock Text="Players connected via browser" FontWeight="SemiBold" />
                  <TextBlock Text="Select a player to view their character sheet." FontSize="12" Foreground="{DynamicResource Brush.Muted}" />

                  <ItemsControl ItemsSource="{Binding RemotePlayers}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:RemotePlayerViewModel">
                        <Border Background="{DynamicResource Brush.SurfaceAlt}"
                                CornerRadius="{DynamicResource Radius.SM}"
                                Padding="12"
                                Margin="0,0,0,8"
                                BorderBrush="{DynamicResource Brush.Surface}"
                                BorderThickness="1">
                          <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <StackPanel Spacing="2">
                              <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                              <TextBlock Text="{Binding Character.Header, TargetNullValue=Waiting for character sheet...}"
                                         FontSize="12"
                                         Foreground="{DynamicResource Brush.Muted}" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="View"
                                    Command="{Binding $parent[TabControl].DataContext.ShowRemotePlayerCommand}"
                                    CommandParameter="{Binding}"
                                    HorizontalAlignment="Right"
                                    MinWidth="80" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <TextBlock Text="No players connected yet."
                             FontStyle="Italic"
                             Foreground="{DynamicResource Brush.Muted}"
                             HorizontalAlignment="Center"
                             Margin="0,20,0,0"
                             IsVisible="{Binding RemotePlayers.Count, Converter={StaticResource ZeroToBool}}" />
                </StackPanel>
              </Grid>

              <Grid IsVisible="{Binding IsRemotePlayerDetailVisible}">
                <StackPanel Spacing="12">
                  <Button Content="Back to players"
                          Command="{Binding BackToRemotePlayerListCommand}"
                          HorizontalAlignment="Left"
                          MinWidth="140" />

                  <TextBlock Text="{Binding ActiveRemotePlayer.Name}"
                             FontSize="18"
                             FontWeight="Bold" />

                  <TextBlock Text="{Binding ActiveRemotePlayer.Character.Header, TargetNullValue=Waiting for character sheet...}"
                             Foreground="{DynamicResource Brush.Muted}" />

                  <ContentControl Content="{Binding ActiveRemotePlayer.Character}"
                                  IsVisible="{Binding ActiveRemotePlayer.Character, Converter={StaticResource NullToBool}}">
                    <ContentControl.ContentTemplate>
                      <DataTemplate x:DataType="vm:CharacterSheetViewModel">
                        <views:CharacterSheetView DataContext="{Binding}" />
                      </DataTemplate>
                    </ContentControl.ContentTemplate>
                  </ContentControl>

                  <TextBlock Text="Waiting for this player to submit their character sheet."
                             FontStyle="Italic"
                             Foreground="{DynamicResource Brush.Muted}"
                             HorizontalAlignment="Center"
                             Margin="0,40,0,0"
                             IsVisible="{Binding ActiveRemotePlayer.Character, Converter={StaticResource NullToBoolInverted}}" />
                </StackPanel>
              </Grid>
            </Grid>
          </TabItem>
        </TabControl>
      </TabItem>

      <!-- Journal tab -->
      <TabItem Header="Journal">
        <Grid RowDefinitions="*,Auto" Margin="10">
          <ListBox ItemsSource="{Binding JournalEntries}">
            <ListBox.ItemTemplate>
              <!-- DO NOT redeclare xmlns here; root already has it -->
              <DataTemplate x:DataType="x:String">
                <TextBlock Text="{Binding .}"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
            <TextBox Text="{Binding NewJournalText, Mode=TwoWay}" Watermark="Add entry..."/>
            <Button Grid.Column="1"
                    Content="Add"
                    Margin="8,0,0,0"
                    Command="{Binding AddJournalEntryCommand}" />
          </Grid>
        </Grid>
      </TabItem>

      <!-- Library tab -->
      <TabItem Header="Library">
        <ListBox ItemsSource="{Binding Compendium}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="m:CompendiumEntry">
              <StackPanel Margin="0,0,0,8">
                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </TabItem>
    </TabControl>

  </DockPanel>
</Window>
